{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@webchain/protocol": ["packages/protocol/src/index.ts"],
      "@webchain/runtime": ["packages/runtime/src/index.ts"],
      "@webchain/asap-adapter": ["packages/adapters/asap/src/index.ts"]
    }
  }
}
